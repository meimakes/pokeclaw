{
  "name": "coding-agent-mcp",
  "version": "1.0.0",
  "description": "MCP server for spawning and controlling Codex CLI and Claude Code sessions",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "test": "node --import tsx --test 'src/**/*.test.ts'",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "codex",
    "claude-code",
    "coding-agent",
    "ai-agent"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/meimakes/coding-agent-mcp.git"
  },
  "homepage": "https://github.com/meimakes/coding-agent-mcp#readme",
  "bugs": {
    "url": "https://github.com/meimakes/coding-agent-mcp/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "express": "^5.1.0",
    "node-pty": "^1.0.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.2",
    "@types/uuid": "^10.0.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.58.0"
  }
}
